{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "enabled": true,
      "timeout": 20000,
      "command": [
        "/home/opencode/.local/bin/uvx",
        "--from",
        "git+https://github.com/oraios/serena@v0.1.4",
        "serena",
        "start-mcp-server"
      ]
    },
    "jcodemunch": {
      "type": "local",
      "enabled": false,
      "timeout": 20000,
      "command": [
        "/home/opencode/.local/bin/uvx",
        "jcodemunch-mcp"
      ],
      "env": {
        "JCODEMUNCH_SHARE_SAVINGS": "0",
        "GITHUB_TOKEN": "<optional-github-token>",
        "ANTHROPIC_API_KEY": "<optional-anthropic-key>",
        "GOOGLE_API_KEY": "<optional-google-key>"
      }
    },
    "jdocmunch": {
      "type": "local",
      "enabled": false,
      "timeout": 20000,
      "command": [
        "/home/opencode/.local/bin/uvx",
        "jdocmunch-mcp"
      ],
      "env": {
        "JDOCMUNCH_SHARE_SAVINGS": "0",
        "GITHUB_TOKEN": "<optional-github-token>",
        "ANTHROPIC_API_KEY": "<optional-anthropic-key>",
        "GOOGLE_API_KEY": "<optional-google-key>"
      }
    }
  }
}
